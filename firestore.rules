rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Allows a user to read their paired partner's data.
    function isPartnerOf(userId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.partnerId == userId;
    }

    match /users/{userId} {
      // Allow reading your own profile and your partner's profile.
      allow get: if isSelf(userId) || isPartnerOf(userId);

      // Used by `findUserByCode()` which does a collection query.
      // This intentionally restricts queries to small result sets to avoid dumping all users.
      allow list: if isSignedIn() && request.query.limit != null && request.query.limit <= 5;

      // Allow users to create their own profile doc.
      allow create: if isSelf(userId);

      // Allow users to update their own profile doc.
      //
      // Partner pairing in this codebase updates BOTH users' docs client-side.
      // To support that, we also allow a signed-in user to set `partnerId` on a target user
      // only when the target is currently unpaired and the new partnerId equals the caller's uid.
      allow update: if isSelf(userId)
        || (
          isSignedIn()
          && resource.data.partnerId == null
          && request.resource.data.partnerId == request.auth.uid
        );

      allow delete: if false;

      // Private subcollections (readable by self; readable by partner where needed).
      match /dailyLogs/{dateId} {
        allow read: if isSelf(userId) || isPartnerOf(userId);
        allow write: if isSelf(userId);
      }

      match /dailyGoalOverrides/{dateId} {
        allow read, write: if isSelf(userId);
      }

      match /meals/{mealId} {
        allow read: if isSelf(userId) || isPartnerOf(userId);
        allow write: if isSelf(userId);
      }

      match /foods/{foodId} {
        allow read, write: if isSelf(userId);
      }

      match /customFoods/{foodId} {
        allow read, write: if isSelf(userId);
      }

      match /presets/{presetId} {
        allow read, write: if isSelf(userId);
      }

      match /calorieBankEntries/{entryId} {
        allow read, write: if isSelf(userId);
      }
    }

    // Weekly challenges: participants can read; only signed-in users can create.
    match /challenges/{challengeId} {
      allow create: if isSignedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;

      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow list: if isSignedIn();

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;
    }

    // Calorie banking sessions: participants can read and update.
    match /calorieBanks/{bankId} {
      allow create: if isSignedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants;

      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow list: if isSignedIn();

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow delete: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

