{
  "expo": {
    "name": "NutriPair",
    "slug": "NutriPair",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutripair",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutripair.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriPair needs camera access to scan food barcodes",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "NutriPair needs camera access to scan food barcodes"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1ae167a7-e442-4da8-87de-3859a9b19544"
      }
    }
  }
}
